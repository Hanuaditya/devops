package com.example

fun addNumbers(num1: Double, num2: Double): Double {
    return num1 + num2
}

fun main() {
    val num1 = 10.0
    val num2 = 5.0

    val result = addNumbers(num1, num2)

    println("The sum of $num1 and $num2 is: $result")
}

